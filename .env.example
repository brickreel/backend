# BrickReel Backend Environment Variables
# Copy this file to .env and fill in the values

# Server port (defaults to 3000 if not set)
PORT=3000

# Node environment — set to "production" in deployment
NODE_ENV=development

# Allowed CORS origin(s). Use * to allow all origins (not recommended in production).
CORS_ORIGIN=http://localhost:3001

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
