# Environment variables for BrickReel backend
# Copy this file to .env and fill in the values

# Server port (defaults to 3000 if not set)
PORT=3000

# Node environment — set to "production" in deployment
NODE_ENV=development

# Allowed CORS origin(s). Use * to allow all origins (not recommended in production).
# CORS_ORIGIN=https://your-frontend-domain.com
